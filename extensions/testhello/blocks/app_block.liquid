<div class="custom-data-container" style="margin: 20px 0;">
  <table border="1" style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="background: #f4f4f4;">
        <th style="padding: 10px;">Shop domain</th>
        <th style="padding: 10px;">Value</th>
      </tr>
    </thead>
    <tbody id="laravel-data-table-body">
      <tr><td colspan="2" style="text-align:center; padding: 20px;">Loading data...</td></tr>
    </tbody>
  </table>
</div>

<script>
(function() {
  const shop = "{{ shop.permanent_domain }}";
  // Double-check this ngrok URL matches your current session exactly!
  const APP_URL = "https://outcome-devices-magazines-interests.trycloudflare.com"; 

  fetch(`${APP_URL}/api/settings-data?shop_domain=${shop}`)
    .then(response => {
      if (!response.ok) throw new Error('Network response was not ok: ' + response.statusText);
      return response.json();
    })
    .then(data => {
      const tbody = document.getElementById('laravel-data-table-body');
      tbody.innerHTML = ""; 

      if (data && data.length > 0) {
        data.forEach(item => {
          tbody.innerHTML += `<tr>
            <td style="padding: 10px;">${item.shop_domain}</td>
            <td style="padding: 10px;">${item.value}</td>
          </tr>`;
        });
      } else {
        tbody.innerHTML = "<tr><td colspan='2' style='text-align:center; padding: 10px;'>No records found.</td></tr>";
      }
    })
    .catch(error => {
      console.error('CORS or Fetch Error:', error);
      document.getElementById('laravel-data-table-body').innerHTML = 
        `<tr><td colspan='2' style='color: red; text-align:center; padding: 10px;'>Error: ${error.message}</td></tr>`;
    });
})();
</script>

{% schema %}
{
  "name": "App Setting Table",
  "target": "section",
  "settings": []
}
{% endschema %}
